@{
    ViewData["Title"] = "Karşılaştırma";
}

<div class="compare-page">

    <header class="compare-header">
        <h1>Karşılaştırma</h1>
        <p>İller arasında yatırım skorlarını radar grafiği ile karşılaştırın.</p>
    </header>

    <section class="compare-filter">
        <div class="filter-group">
            <label>İl 1</label>
            <select id="city1"></select>
        </div>
        <div class="filter-group">
            <label>İl 2</label>
            <select id="city2"></select>
        </div>
        <button onclick="compareCities()">Karşılaştır</button>
    </section>

    <section class="radar-card">
        <div class="radar-wrap">
            <svg id="radarChart" viewBox="0 0 620 500" xmlns="http://www.w3.org/2000/svg"></svg>
        </div>

        <div class="legend">
            <span><i class="dot blue"></i><b id="legend1">—</b></span>
            <span><i class="dot green"></i><b id="legend2">—</b></span>
        </div>

        <div class="scores-grid" id="scoresGrid"></div>
    </section>

</div>

@section Styles {
    <style>
        .compare-page {
            padding: 20px 28px;
        }

        .compare-header {
            margin-bottom: 20px;
        }

            .compare-header h1 {
                margin: 0 0 4px;
                font-size: 22px;
                font-weight: 700;
                color: #101828;
            }

            .compare-header p {
                margin: 0;
                font-size: 13px;
                color: #98a2b3;
            }

        /* ── Filter bar ── */
        .compare-filter {
            background: #fff;
            border: 1px solid #edf1f7;
            border-radius: 16px;
            padding: 16px 20px;
            display: grid;
            grid-template-columns: 1fr 1fr auto;
            gap: 16px;
            align-items: end;
            box-shadow: 0 4px 16px rgba(16,24,40,.05);
            margin-bottom: 20px;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

            .filter-group label {
                font-size: 11px;
                font-weight: 700;
                color: #344054;
                text-transform: uppercase;
                letter-spacing: .5px;
            }

            .filter-group select {
                height: 40px;
                border-radius: 10px;
                border: 1px solid #dbe3ef;
                padding: 0 12px;
                outline: none;
                font-size: 13px;
                color: #344054;
                background: #fff;
                cursor: pointer;
                transition: border-color .15s;
            }

                .filter-group select:focus {
                    border-color: #3157f6;
                }

        .compare-filter button {
            height: 40px;
            padding: 0 22px;
            border: none;
            border-radius: 10px;
            background: #3157f6;
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: background .15s;
            white-space: nowrap;
        }

            .compare-filter button:hover {
                background: #2444d4;
            }

        /* ── Radar card ── */
        .radar-card {
            background: #fff;
            border: 1px solid #edf1f7;
            border-radius: 20px;
            box-shadow: 0 4px 20px rgba(16,24,40,.06);
            padding: 20px 20px 24px;
        }

        .radar-wrap {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        #radarChart {
            width: 100%;
            max-width: 700px;
            height: auto;
        }

        /* ── Legend ── */
        .legend {
            display: flex;
            justify-content: center;
            gap: 32px;
            font-size: 13px;
            color: #344054;
            margin-top: 4px;
            margin-bottom: 20px;
        }

            .legend span {
                display: flex;
                align-items: center;
                gap: 8px;
            }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
        }

            .dot.blue {
                background: #3157f6;
            }

            .dot.green {
                background: #22c55e;
            }

        /* ── Scores grid ── */
        .scores-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .score-cell {
            background: #f8fafc;
            border-radius: 10px;
            padding: 10px 14px;
        }

            .score-cell .sc-label {
                font-size: 11px;
                color: #98a2b3;
                margin-bottom: 6px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .score-cell .sc-vals {
                display: flex;
                align-items: baseline;
                gap: 8px;
                flex-wrap: wrap;
            }

            .score-cell .val {
                font-size: 17px;
                font-weight: 700;
            }

                .score-cell .val.blue {
                    color: #3157f6;
                }

                .score-cell .val.green {
                    color: #22c55e;
                }

            .score-cell .sc-sep {
                font-size: 11px;
                color: #c5ccd8;
            }

        @@media (max-width: 900px) {
            .compare-filter {
                grid-template-columns: 1fr;
            }

            .scores-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 560px) {
            .scores-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@section Scripts {
    <script>
        /* ───────────────────────────────────────────
           Config
        ─────────────────────────────────────────── */
        const CATS = [
            "Ekonomik Güç",
            "Ulaşım & Altyapı",
            "Nüfus & Demografi",
            "Yaşam Kalitesi",
            "Çevre & Sürdürülebilirlik",
            "Yenilik & Teknoloji"
        ];

        // Mapping: API alanları → CATS sırası ile aynı
        const SCORE_KEYS = [
            "yatirimSkoru",
            "ulasimSkoru",
            "nufusSkoru",
            "egitimSkoru",
            "tarimSkoru",
            "madenSkoru"
        ];

        const CX = 310, CY = 242, R = 155, N = CATS.length;

        /* ───────────────────────────────────────────
           State
        ─────────────────────────────────────────── */
        let allData = {};   // { "Kocaeli": [rows], ... }
        let cities  = [];

        /* ───────────────────────────────────────────
           Data loading
        ─────────────────────────────────────────── */
        async function loadCompareData() {
            const res  = await fetch('/api/InvestAnalysis/all');
            const raw  = await res.json();

            raw.forEach(x => {
                if (!allData[x.il]) allData[x.il] = [];
                allData[x.il].push(x);
            });

            cities = Object.keys(allData).sort((a, b) => a.localeCompare(b, 'tr'));

            const sel1 = document.getElementById('city1');
            const sel2 = document.getElementById('city2');

            cities.forEach(city => {
                sel1.innerHTML += `<option value="${city}">${city}</option>`;
                sel2.innerHTML += `<option value="${city}">${city}</option>`;
            });

            sel1.value = cities.includes('Kocaeli') ? 'Kocaeli' : cities[0];
            sel2.value = cities.includes('Bursa')   ? 'Bursa'   : cities[1] || cities[0];

            compareCities();
        }

        /* ───────────────────────────────────────────
           Score calculation
        ─────────────────────────────────────────── */
        function avg(rows, key) {
            const vals = rows.map(x => Number(x[key] || 0));
            return vals.length ? vals.reduce((a, b) => a + b, 0) / vals.length : 0;
        }

        function getCityScores(city) {
            const rows = allData[city] || [];
            return SCORE_KEYS.map(k => Math.round(avg(rows, k)));
        }

        /* ───────────────────────────────────────────
           Geometry helpers
        ─────────────────────────────────────────── */
        function axisPoint(i, factor = 1) {
            const a = -Math.PI / 2 + (Math.PI * 2 * i / N);
            return [CX + R * factor * Math.cos(a), CY + R * factor * Math.sin(a)];
        }

        function valuePoint(i, val) {
            const a = -Math.PI / 2 + (Math.PI * 2 * i / N);
            const r = R * (val / 100);
            return [CX + r * Math.cos(a), CY + r * Math.sin(a)];
        }

        function polyPoints(vals) {
            return vals.map((v, i) => valuePoint(i, v).join(',')).join(' ');
        }

        /* ───────────────────────────────────────────
           SVG drawing
        ─────────────────────────────────────────── */
        function drawRadar(v1, v2) {
            const svg = document.getElementById('radarChart');
            let h = '';

            // Grid rings
            [.2, .4, .6, .8, 1].forEach(f => {
                const pts = Array.from({ length: N }, (_, i) => axisPoint(i, f).join(',')).join(' ');
                h += `<polygon points="${pts}" fill="none" stroke="#eef2f7" stroke-width="1"/>`;
            });

            // Axis lines + labels
            CATS.forEach((cat, i) => {
                const [x, y]   = axisPoint(i);
                const [lx, ly] = axisPoint(i, 1.32);

                h += `<line x1="${CX}" y1="${CY}" x2="${x}" y2="${y}" stroke="#eef2f7" stroke-width="1"/>`;

                const anchor = lx < CX - 8 ? 'end' : lx > CX + 8 ? 'start' : 'middle';
                const parts  = cat.split('&');

                if (parts.length > 1) {
                    h += `<text x="${lx}" y="${ly - 7}" text-anchor="${anchor}" font-size="12" font-weight="600" fill="#667085">${parts[0].trim()}</text>`;
                    h += `<text x="${lx}" y="${ly + 8}" text-anchor="${anchor}" font-size="12" font-weight="600" fill="#667085">& ${parts[1].trim()}</text>`;
                } else {
                    h += `<text x="${lx}" y="${ly + 4}" text-anchor="${anchor}" font-size="12" font-weight="600" fill="#667085">${cat}</text>`;
                }
            });

            // City 1 polygon (blue)
            h += `<polygon points="${polyPoints(v1)}" fill="rgba(49,87,246,0.12)" stroke="#3157f6" stroke-width="2.5" stroke-linejoin="round"/>`;
            // City 2 polygon (green)
            h += `<polygon points="${polyPoints(v2)}" fill="rgba(34,197,94,0.12)" stroke="#22c55e" stroke-width="2.5" stroke-linejoin="round"/>`;

            // Dots
            v1.forEach((v, i) => {
                const [px, py] = valuePoint(i, v);
                h += `<circle cx="${px}" cy="${py}" r="4" fill="#3157f6"/>`;
            });
            v2.forEach((v, i) => {
                const [px, py] = valuePoint(i, v);
                h += `<circle cx="${px}" cy="${py}" r="4" fill="#22c55e"/>`;
            });

            svg.innerHTML = h;
        }

        /* ───────────────────────────────────────────
           Scores grid (below radar)
        ─────────────────────────────────────────── */
        function renderScores(c1, c2, v1, v2) {
            document.getElementById('scoresGrid').innerHTML = CATS.map((cat, i) => `
                <div class="score-cell">
                    <div class="sc-label" title="${cat}">${cat}</div>
                    <div class="sc-vals">
                        <span class="val blue">${v1[i]}</span>
                        <span style="font-size:10px;color:#c5ccd8">${c1}</span>
                        <span class="sc-sep">vs</span>
                        <span class="val green">${v2[i]}</span>
                        <span style="font-size:10px;color:#c5ccd8">${c2}</span>
                    </div>
                </div>`).join('');
        }

        /* ───────────────────────────────────────────
           Main compare action
        ─────────────────────────────────────────── */
        function compareCities() {
            const c1 = document.getElementById('city1').value;
            const c2 = document.getElementById('city2').value;

            document.getElementById('legend1').textContent = c1;
            document.getElementById('legend2').textContent = c2;

            const v1 = getCityScores(c1);
            const v2 = getCityScores(c2);

            drawRadar(v1, v2);
            renderScores(c1, c2, v1, v2);
        }

        loadCompareData();
    </script>
}
