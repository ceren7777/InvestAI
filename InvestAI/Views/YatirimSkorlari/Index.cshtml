@{
    ViewData["Title"] = "Yatırım Skorları";
}

@section Styles {
    <style>
        .scores-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
        }

            .scores-header h1 {
                font-size: 22px;
                font-weight: 700;
                color: #111827;
                margin-bottom: 4px;
            }

            .scores-header p {
                font-size: 13px;
                color: #9ca3af;
            }

        .filter-bar {
            background: white;
            border-radius: 14px;
            border: 1px solid #e8ecf4;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        .filter-label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            white-space: nowrap;
        }

        .filter-bar input, .filter-bar select {
            border: 1px solid #dbe3ef;
            border-radius: 9px;
            padding: 8px 12px;
            font-size: 13px;
            font-family: inherit;
            outline: none;
            color: #111827;
            background: #f8fafc;
        }

        .filter-bar input {
            width: 220px;
        }

            .filter-bar input:focus, .filter-bar select:focus {
                border-color: #3157f6;
                background: white;
            }

        .filter-bar select {
            padding-right: 28px;
        }

        .filter-btn {
            background: #3157f6;
            color: white;
            border: none;
            border-radius: 9px;
            padding: 8px 18px;
            font-size: 13px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
        }

            .filter-btn:hover {
                background: #2445d4;
            }

        .filter-sep {
            flex: 1;
        }

        .result-count {
            font-size: 12px;
            color: #9ca3af;
            white-space: nowrap;
        }

        /* TABLE */
        .table-card {
            background: white;
            border-radius: 16px;
            border: 1px solid #e8ecf4;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            margin-bottom: 16px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            background: #f8fafc;
            padding: 12px 14px;
            font-size: 11.5px;
            font-weight: 700;
            color: #6b7280;
            text-align: left;
            border-bottom: 1px solid #e8ecf4;
            white-space: nowrap;
            user-select: none;
        }

            thead th.sortable {
                cursor: pointer;
            }

                thead th.sortable:hover {
                    color: #3157f6;
                }

            thead th .sort-icon {
                margin-left: 4px;
                opacity: 0.4;
                font-size: 10px;
            }

            thead th.sort-asc .sort-icon::after {
                content: '▲';
                opacity: 1;
                color: #3157f6;
            }

            thead th.sort-desc .sort-icon::after {
                content: '▼';
                opacity: 1;
                color: #3157f6;
            }

            thead th:not(.sort-asc):not(.sort-desc) .sort-icon::after {
                content: '⇅';
            }

        tbody tr {
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.15s;
        }

            tbody tr:last-child {
                border-bottom: none;
            }

            tbody tr:hover {
                background: #f8faff;
            }

            tbody tr.highlighted {
                background: #eef4ff;
            }

        td {
            padding: 12px 14px;
            font-size: 13px;
            color: #374151;
            vertical-align: middle;
        }

            td.rank-cell {
                font-weight: 700;
                color: #9ca3af;
                font-size: 12px;
                width: 40px;
            }

            td.il-cell .il-name {
                font-weight: 700;
                color: #111827;
                font-size: 13.5px;
            }

            td.il-cell .ilce-name {
                font-size: 11px;
                color: #9ca3af;
                margin-top: 2px;
            }

            td.score-cell {
                font-weight: 800;
                font-size: 15px;
                color: #111827;
            }

            td.num-cell {
                color: #374151;
            }

            td.null-cell {
                color: #d1d5db;
                font-size: 12px;
            }

        .score-bar-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .score-mini-bar {
            width: 60px;
            height: 4px;
            background: #e8ecf4;
            border-radius: 2px;
            flex-shrink: 0;
        }

        .score-mini-fill {
            height: 100%;
            border-radius: 2px;
            background: #3157f6;
        }

        .pot-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            white-space: nowrap;
        }

        .pot-high {
            background: #dcfce7;
            color: #15803d;
        }

        .pot-mid {
            background: #fef3c7;
            color: #b45309;
        }

        .pot-low {
            background: #fee2e2;
            color: #b91c1c;
        }

        .tesvik-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            background: #f0f4ff;
            color: #3157f6;
        }

        /* PAGINATION */
        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 4px 0;
        }

        .page-info {
            font-size: 12px;
            color: #9ca3af;
        }

        .page-btns {
            display: flex;
            gap: 4px;
        }

        .page-btn {
            width: 32px;
            height: 32px;
            border: 1px solid #e8ecf4;
            border-radius: 8px;
            background: white;
            font-size: 12px;
            font-weight: 600;
            color: #374151;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.15s;
        }

            .page-btn:hover {
                border-color: #3157f6;
                color: #3157f6;
            }

            .page-btn.active {
                background: #3157f6;
                color: white;
                border-color: #3157f6;
            }

            .page-btn:disabled {
                opacity: 0.35;
                cursor: not-allowed;
            }

        .loading-row td {
            text-align: center;
            padding: 40px;
            color: #9ca3af;
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid #e8ecf4;
            border-top-color: #3157f6;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            vertical-align: middle;
            margin-right: 8px;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* IL DETAIL MODAL */
        .il-row {
            cursor: pointer;
        }

            .il-row:hover .il-name {
                color: #3157f6;
                text-decoration: underline;
            }

            .il-row .il-cell::after {
                content: ' ›';
                font-size: 11px;
                color: #9ca3af;
                margin-left: 4px;
            }

        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.45);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

            .modal-overlay.open {
                display: flex;
            }

        .modal-box {
            background: white;
            border-radius: 20px;
            width: 100%;
            max-width: 1000px;
            max-height: 85vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 60px rgba(0,0,0,0.18);
        }

        .modal-header {
            padding: 20px 24px 16px;
            border-bottom: 1px solid #e8ecf4;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-shrink: 0;
        }

            .modal-header h2 {
                font-size: 18px;
                font-weight: 700;
                color: #111827;
                margin: 0 0 4px;
            }

            .modal-header p {
                font-size: 12px;
                color: #9ca3af;
                margin: 0;
            }

        .modal-close {
            background: #f3f4f6;
            border: none;
            border-radius: 8px;
            width: 32px;
            height: 32px;
            font-size: 18px;
            cursor: pointer;
            color: #6b7280;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            line-height: 1;
        }

            .modal-close:hover {
                background: #e5e7eb;
                color: #111827;
            }

        .modal-body {
            overflow-y: auto;
            padding: 16px 24px 24px;
        }

        .modal-loading {
            text-align: center;
            padding: 48px;
            color: #9ca3af;
        }

        .ilce-table {
            width: 100%;
            border-collapse: collapse;
        }

            .ilce-table thead th {
                background: #f8fafc;
                padding: 10px 12px;
                font-size: 11px;
                font-weight: 700;
                color: #6b7280;
                text-align: left;
                border-bottom: 1px solid #e8ecf4;
                white-space: nowrap;
            }

            .ilce-table tbody tr {
                border-bottom: 1px solid #f1f5f9;
                transition: background 0.1s;
            }

                .ilce-table tbody tr:hover {
                    background: #f8faff;
                }

                .ilce-table tbody tr:last-child {
                    border-bottom: none;
                }

            .ilce-table td {
                padding: 10px 12px;
                font-size: 13px;
                color: #374151;
                vertical-align: middle;
            }

        .ilce-rank {
            font-weight: 700;
            color: #9ca3af;
            font-size: 12px;
            width: 36px;
        }

        .ilce-name-cell {
            font-weight: 600;
            color: #111827;
        }

        .ilce-score {
            font-weight: 800;
            font-size: 14px;
            color: #111827;
        }

        .top1 {
            background: linear-gradient(90deg, #fffbeb 0%, transparent 100%);
        }

        .top2 {
            background: linear-gradient(90deg, #f8fafc 0%, transparent 100%);
        }

        .top3 {
            background: linear-gradient(90deg, #fff7f0 0%, transparent 100%);
        }

        .medal {
            font-size: 16px;
            margin-right: 2px;
        }

        .score-bar-modal {
            display: inline-block;
            width: 50px;
            height: 3px;
            background: #e8ecf4;
            border-radius: 2px;
            vertical-align: middle;
            margin-left: 6px;
        }

        .score-bar-modal-fill {
            height: 100%;
            border-radius: 2px;
            background: #3157f6;
        }

        /* SEKTOR CELL & MODAL */
        .sektor-cell {
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .sektor-cell:hover span:first-child {
                color: #3157f6 !important;
                text-decoration: underline;
            }

        .sektor-more {
            display: inline-block;
            background: #f0f4ff;
            color: #3157f6;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 10px;
            white-space: nowrap;
        }

        .sektor-modal-box {
            background: white;
            border-radius: 16px;
            width: 100%;
            max-width: 480px;
            max-height: 75vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 60px rgba(0,0,0,0.18);
        }

        .sektor-list {
            list-style: none;
            margin: 0;
            padding: 8px 0;
        }

            .sektor-list li {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 20px;
                border-bottom: 1px solid #f1f5f9;
                font-size: 13px;
                color: #374151;
            }

                .sektor-list li:last-child {
                    border-bottom: none;
                }

                .sektor-list li .ilce-tag {
                    font-size: 11px;
                    font-weight: 600;
                    color: #6b7280;
                    min-width: 90px;
                }

        .sektor-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #3157f6;
            flex-shrink: 0;
        }
    </style>
}

<!-- HEADER -->
<div class="scores-header">
    <div>
        <h1>📊 Yatırım Skorları</h1>
        <p>İllerin yatırım potansiyel skorlarını inceleyin ve sıralayın.</p>
    </div>
</div>

<!-- FİLTRELER -->
<div class="filter-bar">
    <span class="filter-label">İl Ara:</span>
    <input type="text" id="searchInput" placeholder="İl adı yazın..." oninput="applyFilters()" />

    <span class="filter-label">Potansiyel:</span>
    <select id="potFilter" onchange="applyFilters()">
        <option value="">Tümü</option>
        <option value="Yüksek">Yüksek</option>
        <option value="Orta">Orta</option>
        <option value="Düşük">Düşük</option>
    </select>

    <span class="filter-label">Sırala:</span>
    <select id="sortSelect" onchange="applyFilters()">
        <option value="yatirim_skoru">Yatırım Skoru</option>
        <option value="osb_skoru">OSB Skoru</option>
        <option value="enerji_skoru">Enerji Skoru</option>
        <option value="tarim_skoru">Tarım Skoru</option>
        <option value="nufus_skoru">Nüfus Skoru</option>
        <option value="maden_skoru">Maden Skoru</option>
    </select>

    <div class="filter-sep"></div>
    <span class="result-count" id="resultCount">Yükleniyor...</span>
</div>

<!-- SEKTOR DETAY MODAL -->
<div class="modal-overlay" id="sektorModal" onclick="closeSektorModalOutside(event)">
    <div class="sektor-modal-box">
        <div class="modal-header">
            <div>
                <h2 id="sektorModalTitle">Sektör Dağılımı</h2>
                <p id="sektorModalSubtitle"></p>
            </div>
            <button class="modal-close" onclick="closeSektorModal()">×</button>
        </div>
        <div class="modal-body" style="padding:0;">
            <ul class="sektor-list" id="sektorList"></ul>
        </div>
    </div>
</div>

<!-- IL DETAY MODAL -->
<div class="modal-overlay" id="ilModal" onclick="closeModalOutside(event)">
    <div class="modal-box">
        <div class="modal-header">
            <div>
                <h2 id="modalTitle">İlçe Detayları</h2>
                <p id="modalSubtitle">İlçelerin yatırım skoru sıralaması</p>
            </div>
            <button class="modal-close" onclick="closeModal()">×</button>
        </div>
        <div class="modal-body">
            <div class="modal-loading" id="modalLoading">
                <span class="spinner"></span> Yükleniyor...
            </div>
            <div id="modalContent" style="display:none;">
                <table class="ilce-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>İlçe</th>
                            <th>Yatırım Skoru</th>
                            <th>OSB</th>
                            <th>Enerji</th>
                            <th>Tarım</th>
                            <th>Nüfus</th>
                            <th>Maden</th>
                            <th>Dominant Sektör</th>
                            <th>Potansiyel</th>
                        </tr>
                    </thead>
                    <tbody id="modalTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- TABLO -->
<div class="table-card">
    <table>
        <thead>
            <tr>
                <th style="width:40px;">#</th>
                <th>İlçe · İl</th>
                <th class="sortable" data-col="osb_skoru" onclick="sortBy('osb_skoru')">OSB Skoru <span class="sort-icon"></span></th>
                <th class="sortable" data-col="enerji_skoru" onclick="sortBy('enerji_skoru')">Enerji Skoru <span class="sort-icon"></span></th>
                <th class="sortable" data-col="tarim_skoru" onclick="sortBy('tarim_skoru')">Tarım Skoru <span class="sort-icon"></span></th>
                <th class="sortable" data-col="nufus_skoru" onclick="sortBy('nufus_skoru')">Nüfus Skoru <span class="sort-icon"></span></th>
                <th class="sortable" data-col="maden_skoru" onclick="sortBy('maden_skoru')">Maden Skoru <span class="sort-icon"></span></th>
                <th>Teşvik Bölgesi</th>
                <th>Dominant Sektör</th>
                <th>Potansiyel</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            <tr class="loading-row"><td colspan="10"><span class="spinner"></span>Veriler yükleniyor...</td></tr>
        </tbody>
    </table>
</div>

<!-- PAGİNASYON -->
<div class="pagination">
    <span class="page-info" id="pageInfo"></span>
    <div class="page-btns" id="pageBtns"></div>
</div>

@section Scripts {
    <script>
        const PAGE_SIZE = 10;
        let allData = [];
        let filtered = [];
        let currentPage = 1;
        let sortCol = 'yatirim_skoru';
        let sortDir = 'desc';

        async function loadData() {
            try {
                const res = await fetch('/api/InvestAnalysis/all');
                const raw = await res.json();

                allData = raw.map(d => ({
                    il:            d.il,
                    ilce:          d.ilce,
                    yatirim_skoru: +(d.yatirimSkoru || 0).toFixed(1),
                    osb_skoru:     +(d.osbSkoru || 0).toFixed(1),
                    enerji_skoru:  +(d.enerjiSkoru || 0).toFixed(1),
                    tarim_skoru:   +(d.tarimSkoru || 0).toFixed(1),
                    nufus_skoru:   +(d.nufusSkoru || 0).toFixed(1),
                    maden_skoru:   +(d.madenSkoru || 0).toFixed(1),
                    tesvik_bolge:  d.tesvikBolge || '-',
                    sektor:        d.ilceDominantSektorAdi || d.ilDominantSektorAdi || 'Karma',
                }));

                applyFilters();
            } catch(e) { console.error(e); }
        }

        function potLabel(score) {
            if (score >= 50) return 'Yüksek';
            if (score >= 40) return 'Orta Yüksek';
            if (score >= 30) return 'Orta';
            return 'Düşük';
        }
        function potBadge(score) {
            const l = potLabel(score);
            const cls = score >= 50 ? 'pot-high' : score >= 40 ? 'pot-mid' : score >= 30 ? 'pot-mid' : 'pot-low';
            return `<span class="pot-badge ${cls}">${l}</span>`;
        }
        function fmt(v, decimals=1) {
            if (v === null || v === undefined) return '<span class="null-cell">—</span>';
            return decimals === 0 ? Number(v).toLocaleString('tr-TR') : Number(v).toFixed(decimals);
        }

        function applyFilters() {
            const search = document.getElementById('searchInput').value.trim().toLowerCase();
            const pot    = document.getElementById('potFilter').value;
            sortCol      = document.getElementById('sortSelect').value;
            sortDir      = 'desc';
            updateSortHeaders();

            filtered = allData.filter(d => {
                if (search && !d.il.toLowerCase().includes(search) && !d.ilce.toLowerCase().includes(search)) return false;
                if (pot && potLabel(d.yatirim_skoru) !== pot) return false;
                return true;
            });

            filtered.sort((a, b) => {
                const va = a[sortCol] || 0, vb = b[sortCol] || 0;
                return sortDir === 'desc' ? vb - va : va - vb;
            });

            document.getElementById('resultCount').textContent = `${filtered.length} ilçe`;
            currentPage = 1;
            render();
        }

        function sortBy(col) {
            if (sortCol === col) sortDir = sortDir === 'desc' ? 'asc' : 'desc';
            else { sortCol = col; sortDir = 'desc'; }
            document.getElementById('sortSelect').value = col;
            filtered.sort((a, b) => {
                const va = a[col] || 0, vb = b[col] || 0;
                return sortDir === 'desc' ? vb - va : va - vb;
            });
            updateSortHeaders();
            currentPage = 1;
            render();
        }

        function updateSortHeaders() {
            document.querySelectorAll('thead th[data-col]').forEach(th => {
                th.classList.remove('sort-asc', 'sort-desc');
                if (th.dataset.col === sortCol) th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
            });
        }

        function render() {
            const start = (currentPage - 1) * PAGE_SIZE;
            const page  = filtered.slice(start, start + PAGE_SIZE);
            const globalStart = start;

            const tbody = document.getElementById('tableBody');
            if (!page.length) {
                tbody.innerHTML = `<tr class="loading-row"><td colspan="10">Sonuç bulunamadı.</td></tr>`;
            } else {
                tbody.innerHTML = page.map((d, i) => {
                    const rank = globalStart + i + 1;
                    const rankMedal = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank;
                    return `<tr class="il-row" onclick="openSektorModal('${d.il.replace(/'/g, "\\'")}', '${d.ilce.replace(/'/g, "\\'")}')">
                        <td class="rank-cell">${rankMedal}</td>
                        <td class="il-cell">
                            <div class="il-name">${d.ilce}</div>
                            <div class="ilce-name">${d.il}</div>
                        </td>
                        <td class="score-cell">
                            <div class="score-bar-wrap">
                                <span>${d.yatirim_skoru}</span>
                                <div class="score-mini-bar"><div class="score-mini-fill" style="width:${Math.min(d.yatirim_skoru,100)}%"></div></div>
                            </div>
                        </td>
                            <td class="num-cell">${fmt(d.osb_skoru)}</td>
                            <td class="num-cell">${fmt(d.enerji_skoru)}</td>
                            <td class="num-cell">${fmt(d.tarim_skoru)}</td>
                            <td class="num-cell">${fmt(d.nufus_skoru)}</td>
                            <td class="num-cell">${fmt(d.maden_skoru)}</td>
                            <td>${d.tesvik_bolge !== '-' ? `<span class="tesvik-badge">Bölge ${d.tesvik_bolge}</span>` : '—'}</td>
                            <td><span style="font-size:12px;color:#374151;">${d.sektor}</span></td>
                            <td>${potBadge(d.yatirim_skoru)}</td>
                    </tr>`;
                }).join('');
            }

            renderPagination();
        }

        function renderPagination() {
            const total = filtered.length;
            const totalPages = Math.ceil(total / PAGE_SIZE);
            const start = (currentPage - 1) * PAGE_SIZE + 1;
            const end   = Math.min(currentPage * PAGE_SIZE, total);

            document.getElementById('pageInfo').textContent = total > 0 ? `${start}–${end} / ${total} ilçe` : '';

            const btns = document.getElementById('pageBtns');
            btns.innerHTML = '';

            const addBtn = (label, page, disabled=false, active=false) => {
                const b = document.createElement('button');
                b.className = 'page-btn' + (active ? ' active' : '');
                b.textContent = label;
                b.disabled = disabled;
                b.onclick = () => { currentPage = page; render(); };
                btns.appendChild(b);
            };

            addBtn('‹', currentPage - 1, currentPage === 1);

            // Page numbers with ellipsis
            const pages = [];
            if (totalPages <= 7) {
                for (let i = 1; i <= totalPages; i++) pages.push(i);
            } else {
                pages.push(1);
                if (currentPage > 3) pages.push('...');
                for (let i = Math.max(2, currentPage-1); i <= Math.min(totalPages-1, currentPage+1); i++) pages.push(i);
                if (currentPage < totalPages - 2) pages.push('...');
                pages.push(totalPages);
            }

            pages.forEach(p => {
                if (p === '...') {
                    const s = document.createElement('span');
                    s.textContent = '...';
                    s.style.cssText = 'padding:0 4px;color:#9ca3af;font-size:12px;display:flex;align-items:center;';
                    btns.appendChild(s);
                } else {
                    addBtn(p, p, false, p === currentPage);
                }
            });

            addBtn('›', currentPage + 1, currentPage === totalPages);
        }

        // ── MODAL ──────────────────────────────────────────────
        function openModal(ilAdi, ilceler) {
            document.getElementById('modalTitle').textContent = '📍 ' + ilAdi + ' – İlçe Sıralaması';
            document.getElementById('modalSubtitle').textContent =
                ilceler.length + ' ilçe · Yatırım skoruna göre sıralanmış';
            document.getElementById('modalLoading').style.display = 'none';
            document.getElementById('modalContent').style.display = 'block';

            const medals = ['🥇', '🥈', '🥉'];
            const rowClasses = ['top1', 'top2', 'top3'];

            const maxScore = ilceler.length > 0 ? (ilceler[0].yatirimSkoru || 1) : 1;

            document.getElementById('modalTableBody').innerHTML = ilceler.map((ilce, i) => {
                const rank = i + 1;
                const rankDisplay = rank <= 3
                    ? `<span class="medal">${medals[i]}</span>`
                    : `<span style="color:#9ca3af;font-size:12px;font-weight:700;">${rank}</span>`;
                const rowCls = rank <= 3 ? rowClasses[i] : '';
                const score = ilce.yatirimSkoru || 0;
                const barPct = Math.round((score / maxScore) * 100);
                const potLabel = score >= 50 ? 'Yüksek' : score >= 40 ? 'Orta Yüksek' : score >= 30 ? 'Orta' : 'Düşük';
                const potCls  = score >= 50 ? 'pot-high' : score >= 40 ? 'pot-mid' : score >= 30 ? 'pot-mid' : 'pot-low';

                return `<tr class="${rowCls}">
                    <td class="ilce-rank">${rankDisplay}</td>
                    <td class="ilce-name-cell">${ilce.ilce}</td>
                    <td class="ilce-score">
                        ${score.toFixed(1)}
                        <span class="score-bar-modal"><span class="score-bar-modal-fill" style="width:${barPct}%;display:block;"></span></span>
                    </td>
                    <td>${fmtM(ilce.osbSkoru)}</td>
                    <td>${fmtM(ilce.enerjiSkoru)}</td>
                    <td>${fmtM(ilce.tarimSkoru)}</td>
                    <td>${fmtM(ilce.nufusSkoru)}</td>
                    <td>${fmtM(ilce.madenSkoru)}</td>
                    <td style="font-size:12px;color:#374151;">${ilce.sektor || '—'}</td>
                    <td><span class="pot-badge ${potCls}">${potLabel}</span></td>
                </tr>`;
            }).join('');

            document.getElementById('ilModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function fmtM(v) {
            if (v === null || v === undefined || v === 0) return '<span style="color:#d1d5db;">—</span>';
            return Number(v).toFixed(1);
        }

        function closeModal() {
            document.getElementById('ilModal').classList.remove('open');
            document.body.style.overflow = '';
        }

        function closeModalOutside(e) {
            if (e.target === document.getElementById('ilModal')) closeModal();
        }

        // ── SEKTOR MODAL ────────────────────────────────────────
        async function openSektorModal(il, ilce) {
            document.getElementById('sektorModal').classList.add('open');
            document.body.style.overflow = 'hidden';
            document.getElementById('sektorModalTitle').textContent = '🏭 ' + ilce + ' – Sektör Dağılımı';
            document.getElementById('sektorModalSubtitle').textContent = il + ' · Çalışan sayısına göre sıralanmış';
            document.getElementById('sektorList').innerHTML = '<li style="justify-content:center;padding:32px;color:#9ca3af;"><span class="spinner"></span> Yükleniyor...</li>';

            try {
                const res = await fetch(`/api/InvestAnalysis/sektor-dagilim/${encodeURIComponent(il)}/${encodeURIComponent(ilce)}`);
                const data = await res.json();

                if (!data || data.length === 0) {
                    document.getElementById('sektorList').innerHTML = '<li style="justify-content:center;padding:32px;color:#9ca3af;">Veri bulunamadı.</li>';
                    return;
                }

                const maxPct = data[0].percentage;
                document.getElementById('sektorModalSubtitle').textContent =
                    il + ' · ' + data.length + ' sektör · Çalışan sayısına göre sıralanmış';

                const medals = ['🥇','🥈','🥉'];
                document.getElementById('sektorList').innerHTML = data.map((s, i) => {
                    const barW = Math.round((s.percentage / maxPct) * 100);
                    const rankDisplay = i < 3 ? medals[i] : `<span style="color:#9ca3af;font-weight:700;font-size:12px;">${i+1}.</span>`;
                    return `<li>
                        <span style="width:28px;text-align:center;flex-shrink:0;">${rankDisplay}</span>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:13px;font-weight:600;color:#111827;margin-bottom:4px;">${s.sectorName}</div>
                            <div style="background:#e8ecf4;border-radius:3px;height:4px;width:100%;">
                                <div style="background:#3157f6;border-radius:3px;height:4px;width:${barW}%;"></div>
                            </div>
                        </div>
                        <span style="font-size:12px;font-weight:700;color:#3157f6;flex-shrink:0;margin-left:10px;">%${Number(s.percentage).toFixed(1)}</span>
                        <span style="font-size:11px;color:#9ca3af;flex-shrink:0;margin-left:8px;">${s.employeeCount.toLocaleString('tr-TR')} çalışan</span>
                    </li>`;
                }).join('');
            } catch(e) {
                document.getElementById('sektorList').innerHTML = '<li style="justify-content:center;padding:32px;color:#ef4444;">Veri yüklenemedi.</li>';
            }
        }

        function closeSektorModal() {
            document.getElementById('sektorModal').classList.remove('open');
            document.body.style.overflow = '';
        }

        function closeSektorModalOutside(e) {
            if (e.target === document.getElementById('sektorModal')) closeSektorModal();
        }
        // ───────────────────────────────────────────────────────

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') { closeModal(); closeSektorModal(); }
        });

        loadData();
    </script>
}
