    <!-- KATEGORİ SKORU SATIRI -->
    <div class="full-width">
        <div class="kategori-skor-row">
            <div class="kat-skor-card"><div class="kat-icon">📈</div><div class="kat-name">Ekonomik Güç</div><div><span class="kat-val" id="kat-ekonomi">-</span><span class="kat-max"> /100</span></div></div>
            <div class="kat-skor-card"><div class="kat-icon">🚛</div><div class="kat-name">Ulaşım & Altyapı</div><div><span class="kat-val" id="kat-ulasim">-</span><span class="kat-max"> /100</span></div></div>
            <div class="kat-skor-card"><div class="kat-icon">👥</div><div class="kat-name">Nüfus & Demografi</div><div><span class="kat-val" id="kat-nufus">-</span><span class="kat-max"> /100</span></div></div>
            <div class="kat-skor-card"><div class="kat-icon">🌿</div><div class="kat-name">Yaşam Kalitesi</div><div><span class="kat-val" id="kat-yasam">-</span><span class="kat-max"> /100</span></div></div>
            <div class="kat-skor-card"><div class="kat-icon">♻️</div><div class="kat-name">Çevre & Sürdürülebilirlik</div><div><span class="kat-val" id="kat-cevre">-</span><span class="kat-max"> /100</span></div></div>
            <div class="kat-skor-card"><div class="kat-icon">💻</div><div class="kat-name">Yenilik & Teknoloji</div><div><span class="kat-val" id="kat-teknoloji">-</span><span class="kat-max"> /100</span></div></div>
