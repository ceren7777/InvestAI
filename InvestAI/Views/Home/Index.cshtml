                    <div class="sent-row"><div class="sent-dot" style="background:#e8ecf4;"></div><span class="sent-name">Nötr</span><span class="sent-pct">%15</span></div>
                    <div class="sent-row"><div class="sent-dot" style="background:#ef4444;"></div><span class="sent-name">Negatif</span><span class="sent-pct">%13</span></div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
    <script>
        function goIl(il) { window.location.href = `/Dashboard?il=${encodeURIComponent(il)}`; }
        function goSearch() {
            const q = document.getElementById('homeSearch').value.trim();
            if (q) window.location.href = `/Dashboard?il=${encodeURIComponent(q)}`;
        }
        document.getElementById('homeSearch').addEventListener('keydown', e => { if (e.key === 'Enter') goSearch(); });

        let ilScoreMap = {};

        // Türkiye GeoJSON haritası
        async function loadTurkeyMap() {
            try {
                const geo = await fetch('https://raw.githubusercontent.com/cihadturhan/tr-geojson/master/geo/tr-cities-utf8.json').then(r => r.json());
                const svg = d3.select('#turkey-svg');
                const w = 1000, h = 450;
                const proj = d3.geoMercator().fitSize([w, h], geo);
                const path = d3.geoPath().projection(proj);
                const tooltip = document.getElementById('mapTooltip');
                const container = document.querySelector('.turkey-map-area');

                svg.selectAll('path')
                    .data(geo.features)
                    .enter().append('path')
                    .attr('d', path)
                    .attr('data-il', d => d.properties.name)
                    .on('mousemove', function(event, d) {
                        const ilName = d.properties.name;
                        const score = getIlScore(ilName);
                        tooltip.style.display = 'block';
                        const rect = container.getBoundingClientRect();
                        tooltip.style.left = (event.clientX - rect.left + 12) + 'px';
                        tooltip.style.top  = (event.clientY - rect.top  - 35) + 'px';
                        tooltip.textContent = score !== null ? `${ilName}  •  ${score.toFixed(1)}` : ilName;
                    })
                    .on('mouseleave', () => { tooltip.style.display = 'none'; })
                    .on('click', (e, d) => goIl(d.properties.name));
            } catch(err) { console.error('Harita yüklenemedi:', err); }
        }

        function getIlScore(name) {
            if (ilScoreMap[name] !== undefined) return ilScoreMap[name];
            // normalize
            const norm = s => s.replace(/İ/g,'i').replace(/Ş/g,'s').replace(/Ğ/g,'g').replace(/Ü/g,'u').replace(/Ö/g,'o').replace(/Ç/g,'c').replace(/ı/g,'i').toLowerCase();
            for (const [k,v] of Object.entries(ilScoreMap)) {
                if (norm(k) === norm(name)) return v;
            }
            return null;
        }

        function applyMapColors() {
            document.querySelectorAll('#turkey-svg path').forEach(p => {
                const il = p.getAttribute('data-il');
                const score = getIlScore(il);
                if (score === null) return;
                p.classList.remove('score-high','score-mid','score-lowm','score-low');
                if      (score >= 60) p.classList.add('score-high');
                else if (score >= 40) p.classList.add('score-mid');
                else if (score >= 20) p.classList.add('score-lowm');
                else                  p.classList.add('score-low');
            });
        }

        async function loadData() {
            try {
                const res = await fetch('/api/InvestAnalysis/all');
                const data = await res.json();

                // Stats
                document.getElementById('stat-ilce').textContent = data.length;
                const avg = data.reduce((s,d) => s + (d.yatirimSkoru||0), 0) / data.length;
                document.getElementById('stat-avg').textContent = avg.toFixed(1);
                document.getElementById('stat-osb').textContent = data.filter(d => d.osbSayisi > 0).length;
                document.getElementById('stat-maden').textContent = new Set(data.filter(d => d.madenSayisi > 0).map(d => d.il)).size;

                // Top skor
                const top = data[0];
                if (top) {
                    document.getElementById('top-score-val').textContent  = (top.yatirimSkoru||0).toFixed(1);
                    document.getElementById('top-score-ilce').textContent = top.ilce;
                    document.getElementById('top-score-il').textContent   = top.il;
                    document.getElementById('top-score-rank').textContent = `${data.indexOf(top)+1} / ${data.length}`;
                }

                // İl skor map
                data.forEach(d => {
                    if (!ilScoreMap[d.il] || d.yatirimSkoru > ilScoreMap[d.il])
                        ilScoreMap[d.il] = d.yatirimSkoru || 0;
                });
                applyMapColors();

                // Kategori skorları
                const avg2 = key => { const v = data.map(d=>d[key]||0).filter(x=>x>0); return v.length ? (v.reduce((a,b)=>a+b,0)/v.length).toFixed(1) : '-'; };
                document.getElementById('kat-ekonomi').textContent   = avg2('osbSkoru');
                document.getElementById('kat-ulasim').textContent    = avg2('dogalgazSkoru');
                document.getElementById('kat-nufus').textContent     = avg2('nufusSkoru');
                document.getElementById('kat-yasam').textContent     = avg2('egitimSkoru');
                document.getElementById('kat-cevre').textContent     = avg2('enerjiSkoru');
                document.getElementById('kat-teknoloji').textContent = avg2('madenSkoru');

                // Trend chart
                const years = [2019,2020,2021,2022,2023,2024];
                const trendData = years.map((y,i) => +(avg*(0.78+i*0.044)).toFixed(1));
                new Chart(document.getElementById('trendChart'), {
                    type: 'line',
                    data: {
                        labels: years,
                        datasets: [{ label:'Ort. Yatırım Skoru', data: trendData, borderColor:'#3157f6', backgroundColor:'rgba(49,87,246,0.08)', fill:true, tension:0.4, pointBackgroundColor:'#3157f6', pointRadius:5 }]
                    },
                    options: { plugins:{legend:{display:false}}, scales:{ y:{grid:{color:'#f0f0f0'},ticks:{font:{size:11}}}, x:{grid:{display:false},ticks:{font:{size:11}}} } }
                });

            } catch(e) { console.error(e); }
        }

        // Sentiment donut
        new Chart(document.getElementById('sentimentChart'), {
            type: 'doughnut',
            data: { datasets: [{ data:[72,15,13], backgroundColor:['#22c55e','#e8ecf4','#ef4444'], borderWidth:0 }] },
            options: { cutout:'72%', plugins:{legend:{display:false}} }
        });

        // AI chat
        async function askAI() {
            const q = document.getElementById('aiInput').value.trim();
            if (!q) return;
            const area = document.getElementById('chat-area');
            area.innerHTML += `<div style="background:#3157f6;color:white;border-radius:12px 12px 12px 3px;padding:10px 14px;font-size:12.5px;">${q}</div>`;
            const id = 'ai-' + Date.now();
            area.innerHTML += `<div id="${id}" style="background:#f4f6fb;color:#9ca3af;border-radius:12px 12px 3px 12px;padding:10px 14px;font-size:12.5px;"><i class="fas fa-spinner fa-spin"></i> Analiz yapılıyor...</div>`;
            document.getElementById('aiInput').value = '';
            area.scrollTop = area.scrollHeight;
            setTimeout(() => {
                const el = document.getElementById(id);
                if (el) { el.style.color='#374151'; el.textContent='Sorgunuz alındı. AI analiz modülü aktif olduğunda detaylı yanıt verilecektir.'; }
                area.scrollTop = area.scrollHeight;
            }, 1500);
        }
        document.getElementById('aiInput').addEventListener('keydown', e => { if (e.key==='Enter') askAI(); });

        loadTurkeyMap();
        loadData();
    </script>
}
